# GCP project ID — run `gcloud config get-value project` to find yours
GCP_PROJECT_ID=your-gcp-project-id

# Bucket name — must be globally unique across all of GCP
# Tip: use something like "prototypes-yourname" or "prototypes-yourcompany"
GCS_BUCKET_NAME=your-prototypes-bucket

# Region (optional, defaults to us-central1)
# GCS_REGION=us-central1
